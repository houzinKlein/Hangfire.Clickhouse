<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Isolate this repository from any inherited (machine/user-level) package feeds.
    All dependencies here are public on nuget.org; clearing avoids slow/401 private feeds.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
